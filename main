import random
import tkinter as tk

#make main page
root = tk.Tk()
root.configure(bg = "#181923")
root.title("The Number Guessing Game")
root.geometry('800x400')

#number to guess
randomNum = 0

#num of attempts
attempt = 0

#my plot
index = 0

plot = ["You were once a successful businessman", 
        "Now you're nothing but a runaway gambler", 
        "The casino owner was very unhappy with your escape",
        "Though you somehow lasted a week",
        "Unfortunatly for you, today is the day you get caught",
        "'ill give you a chance', he said",
        "'You know guess the number right'",
        "'We'll play this game with your life on the line'",
        "'the whole process will be broadcasted live'",
        "'be honored'"]

label = tk.Label(root, text="You were once a successful businessman", pady=150, bg = "#181923", font=("monospace", 30, "bold"), fg="#b59e90",)
label.pack()

#Changes text when next is clicked
def next():
    global index
    index += 1
    if index < len(plot):
        label.config(text=plot[index])
    else:
        #temp hide plot button 
        plotButton.pack_forget()
        label.config(text = "Welcome to the Number Guessing Game!", font=("monospace", 30, "bold"))

        #show start button
        startButton.pack(pady=30)

#Starts the game
def start():
    #Random Number Generation
    global randomNum, forInput
    randomNum = random.randint(1,100)
    label.config(text="Guess A Number 1-100", bg = "#181923")

    #show entry for input
    forInput.pack(pady = 100)

    #show guess button
    confirmButton.pack()

    #temp hide button 
    startButton.pack_forget()

#Check user input
def guessNum():
    global attempt

    if attempt < 10:
        try:
            attempt += 1
            guess = int(forInput.get())

            if 1 <= guess <= 100:
                if guess < randomNum:
                    label.config(text="Too low")
                elif guess > randomNum:
                    label.config(text="Too high")
                else:
                    label.config(text=f'Congratulations! You used {attempt} attempts.')
                    confirmButton.pack_forget()
    
            else:
                label.config(text="Out of bounds :/")

        except ValueError:
            label.config(text="INVALID!!!")
    
    else:
        label.config(text="Congratulations! Out of attempts.\nP.S. You died a miserable death")
        #show replay button
        replayButton.pack(pady=30)
        confirmButton.pack_forget()

def replay():
    global attempt, index

    attempt = 0
    index = 0

    #reset text and input box
    label.config(text=plot[0], font=("monospace", 30, "bold"))
    forInput.delete(0, tk.END)

    #hide button and input box
    replayButton.pack_forget()
    forInput.pack_forget()

    #restart plot
    plotButton.pack()



#buttons
plotButton = tk.Button(root, text="Next", command = next, bg = "#6f687a", font = ("monospace", 20))
plotButton.pack()

startButton = tk.Button(root, text = "START", command = start, font = ("monospace", 20))
startButton.pack_forget()

confirmButton = tk.Button(root, text="Guess", command=guessNum, font = ("monospace", 20))
confirmButton.pack_forget()

replayButton = tk.Button(root, text = "Go Back in Time", command = replay, font = ("monospace", 20))
replayButton.pack_forget()

forInput = tk.Entry(root, width = 15, highlightbackground="gray")
forInput.pack_forget()

root.mainloop()
